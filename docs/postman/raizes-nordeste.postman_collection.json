          ] } }],
          "request": {
            "method": "POST", "header": [],
            "body": { "mode": "raw", "options": { "raw": { "language": "json" } }, "raw": "{\n  \"unidade_id\": 1,\n  \"itens\": [ { \"produto_id\": 1, \"quantidade\": 1 } ]\n}" },
            "url": { "raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "Criar -> 422 itens vazio",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
