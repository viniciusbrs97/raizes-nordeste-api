{
  "info": {
    "name": "Raízes do Nordeste API",
    "description": "Suíte auto-validável da API Raízes do Nordeste (cada request tem pm.test).\n\nFluxo (rode de cima pra baixo no Collection Runner):\n1) Auth > Login (salva token) e Login cliente (salva token_cliente)\n2) Pedidos: criar (salva pedido_id) -> pagar -> status\n3) Cenários de erro / pagamento / máquina de estados\n\nAjuste a variável `senha` com o SUPER_ADMIN_PASSWORD do seu .env. Cliente demo: cliente@raizes.com / cliente123 (criado pelo seed).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token", "value": "" },
    { "key": "token_cliente", "value": "" },
    { "key": "pedido_id", "value": "" },
    { "key": "email", "value": "admin@raizes.com" },
    { "key": "senha", "value": "troque-essa-senha" },
    { "key": "email_cliente", "value": "cliente@raizes.com" },
    { "key": "senha_cliente", "value": "cliente123" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));"
          ] } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login (admin) -> 200 + salva token",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.test('tem access_token', () => pm.expect(j.access_token).to.be.a('string'));",
            "if (j.access_token) pm.collectionVariables.set('token', j.access_token);"
          ] } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "username", "value": "{{email}}", "type": "text" },
              { "key": "password", "value": "{{senha}}", "type": "text" }
            ] },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "POST /auth/login (senha errada) -> 401",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 401', () => pm.response.to.have.status(401));"
          ] } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "username", "value": "{{email}}", "type": "text" },
              { "key": "password", "value": "senha-errada-123", "type": "text" }
            ] },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "POST /auth/login (cliente) -> 200 + salva token_cliente",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "if (j.access_token) pm.collectionVariables.set('token_cliente', j.access_token);"
          ] } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "username", "value": "{{email_cliente}}", "type": "text" },
              { "key": "password", "value": "{{senha_cliente}}", "type": "text" }
            ] },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "GET /auth/me -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "pm.test('sem senha_hash', () => pm.expect(pm.response.json()).to.not.have.property('senha_hash'));"
          ] } }],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "GET /pedidos SEM token -> 401",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 401', () => pm.response.to.have.status(401));"
          ] } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "POST /pedidos (criar) -> 201 + salva pedido_id",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 201', () => pm.response.to.have.status(201));",
            "const j = pm.response.json();",
            "pm.test('status pendente', () => pm.expect(j.status).to.eql('pendente'));",
            "if (j.id) pm.collectionVariables.set('pedido_id', j.id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "raw", "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"unidade_id\": 1,\n  \"canal_pedido\": \"totem\",\n  \"itens\": [\n    { \"produto_id\": 1, \"quantidade\": 2 },\n    { \"produto_id\": 3, \"quantidade\": 1 }\n  ]\n}" },
            "url": { "raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "GET /pedidos (listar + filtro + paginação) -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "pm.test('é lista', () => pm.expect(pm.response.json()).to.be.an('array'));"
          ] } }],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"],
              "query": [
                { "key": "canalPedido", "value": "totem", "disabled": true },
                { "key": "skip", "value": "0", "disabled": true },
                { "key": "limit", "value": "20", "disabled": true }
              ] }
          }
        },
        {
          "name": "GET /pedidos/{id} -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));"
          ] } }],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/pedidos/{{pedido_id}}", "host": ["{{base_url}}"], "path": ["pedidos", "{{pedido_id}}"] }
          }
        },
        {
          "name": "POST /pedidos/{id}/pagamento -> 200 confirmado",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "pm.test('confirmado', () => pm.expect(pm.response.json().status).to.eql('confirmado'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/pedidos/{{pedido_id}}/pagamento", "host": ["{{base_url}}"], "path": ["pedidos", "{{pedido_id}}", "pagamento"] }
          }
        },
        {
          "name": "POST pagamento de novo -> 409 (já pago)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 409', () => pm.response.to.have.status(409));",
            "pm.test('error pedido-nao-pendente', () => pm.expect(pm.response.json().error).to.eql('pedido-nao-pendente'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/pedidos/{{pedido_id}}/pagamento", "host": ["{{base_url}}"], "path": ["pedidos", "{{pedido_id}}", "pagamento"] }
          }
        },
        {
          "name": "PATCH /pedidos/{id}/status (em_preparo) -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "pm.test('em_preparo', () => pm.expect(pm.response.json().status).to.eql('em_preparo'));"
          ] } }],
          "request": {
            "method": "PATCH",
            "header": [],
            "body": { "mode": "raw", "options": { "raw": { "language": "json" } }, "raw": "{\n  \"status\": \"em_preparo\"\n}" },
            "url": { "raw": "{{base_url}}/pedidos/{{pedido_id}}/status", "host": ["{{base_url}}"], "path": ["pedidos", "{{pedido_id}}", "status"] }
          }
        }
      ]
    },
    {
      "name": "Cenários de erro (criar)",
