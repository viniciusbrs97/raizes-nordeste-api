            "body": { "mode": "raw", "options": { "raw": { "language": "json" } }, "raw": "{\n  \"unidade_id\": 1,\n  \"canal_pedido\": \"web\",\n  \"itens\": [ { \"produto_id\": 4, \"quantidade\": 1 } ]\n}" },
            "url": { "raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "Criar -> 409 estoque insuficiente",
