    {
      "name": "Máquina de estados & permissão",
      "item": [
        {
          "name": "Criar p/ transição (pendente) -> 201",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 201', () => pm.response.to.have.status(201));",
            "const j = pm.response.json();",
            "if (j.id) pm.collectionVariables.set('pedido_id', j.id);"
          ] } }],
          "request": {
            "method": "POST", "header": [],
            "body": { "mode": "raw", "options": { "raw": { "language": "json" } }, "raw": "{\n  \"unidade_id\": 1,\n  \"canal_pedido\": \"totem\",\n  \"itens\": [ { \"produto_id\": 1, \"quantidade\": 1 } ]\n}" },
