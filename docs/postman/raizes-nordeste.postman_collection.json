          ] } }],
          "request": {
            "method": "POST", "header": [],
            "body": { "mode": "raw", "options": { "raw": { "language": "json" } }, "raw": "{\n  \"unidade_id\": 1,\n  \"canal_pedido\": \"totem\",\n  \"itens\": [ { \"produto_id\": 5, \"quantidade\": 1 } ]\n}" },
            "url": { "raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"] }
          }
        },
